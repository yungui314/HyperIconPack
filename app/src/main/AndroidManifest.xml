<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- miuix-blur is called only after its runtime shader capability check. -->
    <uses-sdk tools:overrideLibrary="top.yukonga.miuix.kmp.blur" />

    <!--
      The converter produces a system-theme archive for every installed app,
      including disabled and non-launcher system packages.  Intent <queries>
      cannot reveal that complete set on Android 11+, so this visibility
      permission is required for the user-requested all-app conversion.
    -->
    <uses-permission android:name="android.permission.QUERY_ALL_PACKAGES" />

    <!--
      Public icon-pack discovery contracts used by mainstream launchers.
    -->
    <queries>
        <!-- Lets the converter enumerate only user-launchable activities when
             it generates static fallback icons for otherwise unmapped apps. -->
        <intent>
            <action android:name="android.intent.action.MAIN" />
            <category android:name="android.intent.category.LAUNCHER" />
        </intent>
        <intent>
            <action android:name="org.adw.launcher.THEMES" />
            <category android:name="android.intent.category.DEFAULT" />
        </intent>
        <intent>
            <action android:name="com.novalauncher.THEME" />
        </intent>
        <intent>
            <action android:name="android.intent.action.MAIN" />
            <category android:name="com.anddoes.launcher.THEME" />
        </intent>
        <intent>
            <action android:name="com.gau.go.launcherex.theme" />
        </intent>
        <intent>
            <action android:name="ch.deletescape.lawnchair.ICONPACK" />
        </intent>
        <intent>
            <action android:name="com.lge.launcher2.THEME" />
        </intent>
    </queries>

    <application
        android:allowBackup="false"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.HyperIconPack">

        <activity
            android:name=".ui.MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!--
          Only exposes a non-sensitive, read-only configuration snapshot.
          The injected com.miui.home process reads it through ContentResolver;
          this avoids world-readable SharedPreferences on modern Android.
        -->
        <provider
            android:name=".config.IconConfigProvider"
            android:authorities="io.github.cl0ura.hypericonpack.config"
            android:exported="true"
            android:grantUriPermissions="false" />

        <!--
          New applications receive an immediate Xposed cache-miss icon and
          this receiver subsequently writes only that package into a revised
          static theme archive. The user never has to rerun all mappings just
          because one app was installed.
        -->
        <receiver
            android:name=".systemtheme.PackageThemeArchiveUpdateReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="android.intent.action.PACKAGE_ADDED" />
                <action android:name="android.intent.action.PACKAGE_REPLACED" />
                <data android:scheme="package" />
            </intent-filter>
        </receiver>

        <service
            android:name=".systemtheme.PackageThemeArchiveUpdateJobService"
            android:exported="false"
            android:permission="android.permission.BIND_JOB_SERVICE" />

        <!-- Classic Xposed module metadata, understood by LSPosed as well. -->
        <meta-data
            android:name="xposedmodule"
            android:value="true" />
        <meta-data
            android:name="xposedminversion"
            android:value="82" />
        <!-- Recommended, not enforced: LSPosed shows these two app scopes. -->
        <meta-data
            android:name="xposedscope"
            android:resource="@array/xposedscope" />
        <meta-data
            android:name="xposeddescription"
            android:value="Use standard third-party icon packs in Xiaomi HyperOS System Launcher." />
    </application>
</manifest>
