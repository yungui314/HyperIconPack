<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- miuix-blur is called only after its runtime shader capability check. -->
    <uses-sdk tools:overrideLibrary="top.yukonga.miuix.kmp.blur" />

    <!--
      The converter produces a system-theme archive for every installed app,
      including disabled and non-launcher system packages.  Intent <queries>
      cannot reveal that complete set on Android 11+, so this visibility
      permission is required for the user-requested all-app conversion.
    -->
    <uses-permission
        android:name="android.permission.QUERY_ALL_PACKAGES"
        tools:ignore="QueryAllPackagesPermission" />
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />

    <!--
      Public icon-pack discovery contracts used by mainstream launchers.
    -->
    <queries>
        <!-- Lets the converter enumerate only user-launchable activities when
             it generates static fallback icons for otherwise unmapped apps. -->
        <intent>
            <action android:name="android.intent.action.MAIN" />
            <category android:name="android.intent.category.LAUNCHER" />
        </intent>
        <intent>
            <action android:name="org.adw.launcher.THEMES" />
            <category android:name="android.intent.category.DEFAULT" />
        </intent>
        <intent>
            <action android:name="com.novalauncher.THEME" />
        </intent>
        <intent>
            <action android:name="android.intent.action.MAIN" />
            <category android:name="com.anddoes.launcher.THEME" />
        </intent>
        <intent>
            <action android:name="com.gau.go.launcherex.theme" />
        </intent>
        <intent>
            <action android:name="ch.deletescape.lawnchair.ICONPACK" />
        </intent>
        <intent>
            <action android:name="com.lge.launcher2.THEME" />
        </intent>
    </queries>

    <application
        android:name=".HyperIconPackApplication"
        android:allowBackup="false"
        android:description="@string/xposed_description"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.HyperIconPack">

        <activity
            android:name=".ui.MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- New applications are added to the native theme archive in one
             coalesced background update; no live icon replacement is used. -->
        <receiver
            android:name=".systemtheme.PackageThemeArchiveUpdateReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="android.intent.action.PACKAGE_ADDED" />
                <action android:name="android.intent.action.PACKAGE_REPLACED" />
                <data android:scheme="package" />
            </intent-filter>
        </receiver>

        <service
            android:name=".systemtheme.PackageThemeArchiveUpdateJobService"
            android:exported="false"
            android:permission="android.permission.BIND_JOB_SERVICE" />

        <!-- Re-schedule durable package-archive updates after reboot so a queue
             written before power-off is not stranded until the next install. -->
        <receiver
            android:name=".systemtheme.PackageThemeArchiveUpdateBootReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
            </intent-filter>
        </receiver>


        <service
            android:name=".systemtheme.IconArchiveConversionService"
            android:exported="false"
            android:foregroundServiceType="dataSync" />

    </application>
</manifest>
