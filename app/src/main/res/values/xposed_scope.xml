<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!--
      LSPosed reads this standard metadata array as recommended scopes.  Home
      owns the launch/return transition bridge and the provider-backed live
      fallback. The remaining packages use the same read-only provider when
      HyperOS Theme Manager removes or bypasses the private static archive.
    -->
    <string-array name="xposedscope">
        <item>com.miui.home</item>
        <item>com.android.systemui</item>
        <item>com.android.settings</item>
        <item>com.miui.securitycenter</item>
        <item>com.xiaomi.misettings</item>
        <item>com.miui.personalassistant</item>
    </string-array>
</resources>
